# Basecone-inboxadres dat jouw boekhouder voor jou heeft aangemaakt
BASECONE_ADDRESS=gel415.g4151017@mailtobasecone.com

# Bearer-token voor /api/intake (zelf verzinnen, deel je met de webclient onder Instellingen)
INTAKE_SECRET=

# Bearer-token voor /api/poll-mail (zelf verzinnen; Vercel Cron stuurt ook x-vercel-cron)
CRON_SECRET=

# Mailbox @himbv.nl: login + afzenderadres (vaak het volledige e-mailadres)
MAILBOX_USER=patrickholterman@himbv.nl
MAILBOX_PASSWORD=

# SMTP (versturen). Vraag deze op bij je hostingpartij.
SMTP_HOST=
SMTP_PORT=465          # 465 = TLS, gebruik 587 voor STARTTLS

# IMAP (mail ophalen). Vaak dezelfde host als SMTP.
IMAP_HOST=
IMAP_PORT=993

# Naam van de map waarin doorgestuurde facturen belanden
INTAKE_FOLDER=Bonnen-intake

# OpenAI voor OCR (gpt-4o-mini vision)
OPENAI_API_KEY=

# Neon Postgres connection string
DATABASE_URL=
